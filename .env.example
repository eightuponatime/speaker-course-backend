PUBLIC_URL=https://example.com
HTTP_PORT=80
# If a host nginx/caddy terminates HTTPS, bind compose only to localhost, e.g.
# HTTP_PORT=127.0.0.1:8088

POSTGRES_DB=speaker_course
POSTGRES_USER=speaker_course
POSTGRES_PASSWORD=change-me
# Local-only Postgres port for SSH tunnel / DBeaver access.
DB_PORT=127.0.0.1:5432

BUSINESS_TIMEZONE=Asia/Almaty
SESSION_TTL=720h

# Leave empty for same-origin API through frontend nginx.
VITE_API_BASE_URL=
VITE_COURSE_ID=10000000-0000-0000-0000-000000000001
VITE_COURSE_SLUG=homemade-bagels-for-beginners

# Google OAuth, optional.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://example.com/auth/google/callback

# Bunny, optional unless media uploads are used.
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_ENDPOINT=https://storage.bunnycdn.com
BUNNY_STORAGE_PUBLIC_BASE_URL=
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_EMBED_BASE_URL=https://iframe.mediadelivery.net/embed

# Transactional email via Resend, optional.
RESEND_API_KEY=
EMAIL_FROM=Logos Voice <noreply@example.com>
